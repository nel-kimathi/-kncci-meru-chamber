  { src: "/images/gallery-page/Gallery-17.jpg", alt: "Gallery image 17", category: "Leadership" },
  { src: "/images/gallery-page/Gallery-18.jpg", alt: "Gallery image 18", category: "Events" },
  { src: "/images/gallery-page/Gallery-19.jpg", alt: "Gallery image 19", category: "Community" },
  { src: "/images/gallery-page/Gallery-20.jpg", alt: "Gallery image 20", category: "Training" },
  { src: "/images/gallery-page/Gallery-21.jpg", alt: "Gallery image 21", category: "Events" },
  { src: "/images/gallery-page/Gallery-22.jpg", alt: "Gallery image 22", category: "Leadership" },
