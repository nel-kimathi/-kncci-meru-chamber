  { src: "/images/gallery-page/Gallery-25.jpg", alt: "Gallery image 25", category: "Training" },
  { src: "/images/gallery-page/Gallery-26.jpg", alt: "Gallery image 26", category: "Events" },
  { src: "/images/gallery-page/Gallery-27.jpg", alt: "Gallery image 27", category: "Leadership" },
  { src: "/images/gallery-page/Gallery-28.jpg", alt: "Gallery image 28", category: "Events" },
  { src: "/images/gallery-page/Gallery-29.jpg", alt: "Gallery image 29", category: "Community" },
  { src: "/images/gallery-page/Gallery-30.jpg", alt: "Gallery image 30", category: "Training" },
