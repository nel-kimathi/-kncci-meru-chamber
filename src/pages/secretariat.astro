---
import Base from '../layouts/Base.astro';
import SectionDivider from '../components/SectionDivider.astro';
import ScrollReveal from '../components/ScrollReveal.astro';

const leadership = [
  {
    role: "Chairman",
    name: "Joshua K. Mungania",
    photo: "/images/chairman-potrait-secretariat/WhatsApp Image 2026-07-16 at 12.06.13 PM.jpeg",
    bio: "The Chairman is a distinguished business leader and entrepreneur dedicated to advancing trade, supporting entrepreneurship, and fostering a business environment that drives innovation, investment, and sustainable economic growth. As Chairman of the Kenya National Chamber of Commerce and Industry (KNCCI) – Meru Chapter, he is committed to strengthening collaboration between the public and private sectors while championing initiatives that empower businesses, create opportunities for enterprise development, and contribute to the economic prosperity of Meru County and beyond.",
  },
];

const board = [
  { name: "Eva Seraphina", role: "Director", photo: "/images/board-directors-images/WhatsApp Image 2026-07-16 at 12.06.17 PM.jpeg" },
  { name: "John Mutuma Ngeera", role: "Director", photo: "/images/board-directors-images/WhatsApp Image 2026-07-16 at 12.06.19 PM (1).jpeg" },
  { name: "James Kirema", role: "Director", photo: "/images/board-directors-images/WhatsApp Image 2026-07-16 at 12.06.19 PM.jpeg" },
  { name: "Mustaq Isaac", role: "Director", photo: "/images/board-directors-images/WhatsApp Image 2026-07-16 at 12.06.20 PM (1).jpeg" },
  { name: "Robert Mithika", role: "Director", photo: "/images/board-directors-images/WhatsApp Image 2026-07-16 at 12.06.20 PM.jpeg" },
  { name: "Veronica Kihenja", role: "Director", photo: "/images/board-directors-images/WhatsApp Image 2026-07-16 at 12.06.21 PM (1).jpeg" },
  { name: "Samuel Kaumbuthu", role: "Director", photo: "/images/board-directors-images/WhatsApp Image 2026-07-16 at 12.06.21 PM.jpeg" },
  { name: "William Wambugu", role: "Director", photo: "/images/board-directors-images/WhatsApp Image 2026-07-16 at 12.06.23 PM.jpeg" },
];

const secretariat = [
  {
    role: "Chief Executive Officer",
    name: "Martin Kiogora",
    photo: "/images/ceo-potrait-secretariat/WhatsApp Image 2026-07-16 at 12.06.15 PM.jpeg",
    bio: "[Brief biography — pending from chamber secretariat.]",
  },
  {
    role: "Head of Marketing",
    name: "Patrick Kathurima",
    photo: "/images/head-of-marketing-potrait-about-us-page/marketing-portrait.jpg",
    bio: "[Brief biography — pending from chamber secretariat.]",
  },
  {
    role: "Admin / IT Officer",
    name: "Nelson Kimathi",
    photo: "/images/admin-it-potrait-about-us-page/admin-it-portrait.jpg",
    bio: "[Brief biography — pending from chamber secretariat.]",
  },
];
---

<Base title="Secretariat" description="Meet the leadership and secretariat of KNCCI Meru Chapter — the Chairman, Board of Directors, and executive team.">
  <!-- Page Hero -->
  <section class="relative bg-black py-20 lg:py-32 min-h-[50vh] flex items-center overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-secretariat/WhatsApp Image 2026-07-16 at 12.06.18 PM.jpeg" alt="" class="w-full h-full object-cover object-top opacity-50" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/50 to-transparent"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
      <div class="max-w-xl lg:max-w-2xl">
        <p class="font-mono text-red text-xs uppercase tracking-widest mb-3">Our Leadership</p>
        <h1 class="font-display font-black text-4xl sm:text-5xl lg:text-5xl text-white leading-tight mb-4">The Secretariat</h1>
        <p class="text-white/70 text-lg lg:text-xl leading-relaxed">
          The people guiding and governing KNCCI Meru Chapter — the Chairman, Board of Directors, and executive secretariat team.
        </p>
      </div>
    </div>
  </section>

  <SectionDivider class="my-0" />

  <!-- Chairman -->
  <section class="bg-white py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="font-display font-black text-3xl lg:text-4xl text-black">Leadership of the Chamber</h2>
      </div>
      {leadership.map((person) => (
        <div class="grid md:grid-cols-3 gap-8 items-center max-w-4xl mx-auto">
          <div class="aspect-[4/5] bg-black/10 rounded-sm overflow-hidden">
            <img src={person.photo} alt={person.name} class="w-full h-full object-cover object-top" loading="lazy" />
          </div>
          <div class="md:col-span-2">
            <p class="font-mono text-red text-xs uppercase tracking-wider mb-1">{person.role}</p>
            <h3 class="font-display font-bold text-2xl text-black mb-3">{person.name}</h3>
            <p class="text-black/60 leading-relaxed text-justify">{person.bio}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <SectionDivider class="my-0" />

  <!-- Board of Directors -->
  <section class="bg-black py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="font-mono text-red text-xs uppercase tracking-widest mb-2">Governance</p>
        <h2 class="font-display font-black text-3xl lg:text-4xl text-white">Board of Directors</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {board.map((member) => (
          <div class="card-reveal group">
            <div class="aspect-[4/5] bg-white/10 rounded-sm overflow-hidden mb-4">
              <img src={member.photo} alt={member.name} class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            </div>
            <p class="font-mono text-red text-xs uppercase tracking-wider">{member.role}</p>
            <h3 class="font-display font-bold text-base text-white mt-1">{member.name}</h3>
          </div>
        ))}
      </div>
    </div>
  </section>

  <ScrollReveal />

  <SectionDivider class="my-0" />

  <!-- Executive Secretariat -->
  <section class="bg-white py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="font-mono text-red text-xs uppercase tracking-widest mb-2">Secretariat Team</p>
        <h2 class="font-display font-black text-3xl lg:text-4xl text-black">Executive Officers</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {secretariat.map((person) => (
          <div class="card-reveal group">
            <div class="aspect-[4/5] bg-black/10 rounded-sm overflow-hidden mb-4">
              <img src={person.photo} alt={person.name} class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            </div>
            <p class="font-mono text-red text-xs uppercase tracking-wider">{person.role}</p>
            <h3 class="font-display font-bold text-lg text-black mt-1 mb-2">{person.name}</h3>
            <p class="text-black/60 text-sm leading-relaxed">{person.bio}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <SectionDivider class="my-0" />

  <!-- CTA -->
  <section class="bg-red py-16 lg:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display font-black text-3xl lg:text-4xl text-white mb-4">
        Want to Get Involved?
      </h2>
      <p class="text-white/80 text-lg mb-8 max-w-xl mx-auto leading-relaxed">
        Join KNCCI Meru Chapter and connect with Meru's business leadership.
      </p>
      <a href="https://erp.kenyachamber.or.ke/kncci_meru/membership" target="_blank" rel="noopener noreferrer" class="inline-flex items-center px-10 py-4 bg-white text-black font-display font-bold text-lg rounded-sm hover:bg-green transition-colors">
        Register Now
      </a>
    </div>
  </section>
</Base>
