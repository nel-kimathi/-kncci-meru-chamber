---
import Base from '../layouts/Base.astro';
import SectionDivider from '../components/SectionDivider.astro';
import ScrollReveal from '../components/ScrollReveal.astro';

const individualTiers = [
  {
    name: "Individual / SME Membership",
    price: "KES 2,500",
    period: "/year",
    ideal: "Individuals, startups, and small & medium-sized enterprises (SMEs).",
    features: [
      "Access to business networking events",
      "Advocacy and representation",
      "Business support services",
      "Training and capacity-building opportunities",
      "Access to KNCCI business resources",
    ],
  },
];

const companyTiers = [
  {
    name: "Registered Business Membership",
    price: "KES 5,000",
    period: "/year",
    ideal: "Registered businesses seeking greater visibility and business growth opportunities.",
    popular: true,
    features: [
      "Business networking opportunities",
      "Policy advocacy and representation",
      "Access to business development programs",
      "Training, workshops, and seminars",
      "Exclusive member resources",
    ],
  },
  {
    name: "Corporate & SACCO Membership",
    price: "KES 50,000",
    period: "/year",
    ideal: "Corporations, financial institutions, and SACCOs.",
    features: [
      "High-level business networking",
      "Corporate advocacy and policy engagement",
      "Strategic partnerships",
      "Access to exclusive business forums",
      "Enhanced visibility within the Chamber network",
    ],
  },
  {
    name: "Recruitment Agency Membership",
    price: "KES 55,000",
    period: "/year",
    ideal: "Recruitment firms and human resource service providers.",
    features: [
      "Networking with employers and businesses",
      "Industry advocacy",
      "Access to Chamber events",
      "Business support services",
      "Opportunities for strategic partnerships",
    ],
  },
  {
    name: "Large Farm Membership",
    price: "KES 100,000",
    period: "/year",
    ideal: "Large-scale agricultural enterprises and commercial farms.",
    features: [
      "Sector-specific advocacy",
      "Access to agricultural trade opportunities",
      "Business networking and partnerships",
      "Investment and market linkage opportunities",
      "Chamber support and business resources",
    ],
  },
];

const benefits = [
  { icon: "M12 22c1.1 0 2-.9 2-2h-4a2 2 0 002 2zm6-6v-5c0-3.07-1.64-5.64-4.5-6.32V4c0-.83-.67-1.5-1.5-1.5s-1.5.67-1.5 1.5v.68C7.63 5.36 6 7.92 6 11v5l-2 2v1h16v-1l-2-2z", title: "Advocacy & Policy Representation", desc: "The Chamber represents Meru's business interests at county and national government level, ensuring that policies support trade and enterprise growth." },
  { icon: "M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z", title: "Networking & Business Connections", desc: "Monthly and quarterly networking forums, business lunches, and events connecting you with fellow business leaders, investors, and government officials." },
  { icon: "M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z", title: "Trade Fairs, Expos & Market Access", desc: "Participate in chamber-organised trade fairs and exhibitions that connect Meru producers with national and international buyers." },
  { icon: "M5 13.18v4L12 21l7-3.82v-4L12 17l-7-3.82zM12 3L1 9l11 6 9-4.91V17h2V9L12 3z", title: "Capacity Building & Training", desc: "Access training workshops on business skills, compliance, export readiness, digital tools, and financial management." },
  { icon: "M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z", title: "Dispute Arbitration & Mediation", desc: "Professional mediation and arbitration services for commercial disputes, saving time and cost compared to court proceedings." },
  { icon: "M12 7V3H2v18h20V7H12zM6 19H4v-2h2v2zm0-4H4v-2h2v2zm0-4H4V9h2v2zm0-4H4V5h2v2zm4 12H8v-2h2v2zm0-4H8v-2h2v2zm0-4H8V9h2v2zm0-4H8V5h2v2zm10 12h-8v-2h2v-2h-2v-2h2v-2h-2V9h8v10zm-2-8h-2v2h2v-2zm0 4h-2v2h2v-2z", title: "County & National Government Access", desc: "Direct engagement channels with county and national government on business matters, tenders, and policy consultations." },
];

const services = [
  { id: "certificate-of-origin", title: "Certificate of Origin", desc: "Application and processing of Certificates of Origin for export goods — particularly critical for Meru's horticultural exports including coffee, tea, French beans, and dairy products." },
  { id: "advocacy", title: "Business Advocacy", desc: "Representation on policy and regulatory issues affecting Meru traders, from county levies to national trade policy." },
  { id: "arbitration", title: "Arbitration Services", desc: "Professional mediation and dispute resolution between members, providing faster and more cost-effective alternatives to court proceedings." },
  { id: "capacity-building", title: "Capacity Building & Training", desc: "Workshops on business skills, financial management, compliance, export readiness, and digital tools for enterprises of all sizes." },
  { id: "trade-missions", title: "Trade Missions & Trade Information", desc: "Organised trade missions to regional and international markets, plus regular trade intelligence bulletins and market reports." },
  { id: "government-liaison", title: "Diplomatic / Government Liaison", desc: "Facilitating connections between members and county/national government for tenders, policy input, and regulatory guidance." },
];
---

<Base title="Benefits / Why Choose Us" description="Discover the benefits of joining KNCCI Meru Chapter — advocacy, networking, training, trade fairs, dispute resolution, and government access.">
  <!-- Page Hero -->
  <section class="relative bg-black py-20 lg:py-32 min-h-[50vh] flex items-center">
    <div class="absolute inset-0">
      <img src="/images/membership-benefits-hero-benefits-page/people-office-work-day.jpg" alt="KNCCI Meru Chapter — Membership Benefits" class="w-full h-full object-cover object-center opacity-50" />
      <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/50 to-transparent"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
      <div class="max-w-xl lg:max-w-2xl">
        <p class="font-mono text-red text-xs uppercase tracking-widest mb-3">Why Join Us</p>
        <h1 class="font-display font-black text-4xl sm:text-5xl lg:text-5xl text-white leading-tight mb-4">Membership Benefits</h1>
        <p class="text-white/70 text-lg lg:text-xl leading-relaxed">
          Discover why hundreds of Meru businesses choose KNCCI Meru Chapter as their trade association — and what you gain as a member.
        </p>
      </div>
    </div>
  </section>

  <SectionDivider class="my-0" />

  <!-- Membership Tiers -->
  <section class="bg-white py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="font-mono text-red text-xs uppercase tracking-widest mb-2">Membership</p>
        <h2 class="font-display font-black text-3xl lg:text-4xl text-black mb-4">Choose the Membership That Fits Your Business</h2>
        <p class="text-black/60 max-w-2xl mx-auto leading-relaxed">
          Become a member of KNCCI Meru Chapter and gain access to exclusive networking opportunities, business advocacy, capacity-building programs, market linkages, and resources designed to help your business grow.
        </p>
      </div>

      <!-- Tab Navigation -->
      <div class="flex justify-center mb-10">
        <div class="inline-flex border border-black/10 rounded-[20px] p-1 bg-black/5">
          <button id="tab-individual" class="tier-tab px-6 py-2.5 rounded-[20px] text-sm font-display font-bold transition-all duration-200 bg-black text-white" data-tab="individual">
            Individual / SME
          </button>
          <button id="tab-company" class="tier-tab px-6 py-2.5 rounded-[20px] text-sm font-display font-bold transition-all duration-200 text-black/50 hover:text-black" data-tab="company">
            Registered Business &amp; Corporate
          </button>
        </div>
      </div>

      <!-- Individual / SME Tab -->
      <div id="panel-individual" class="tier-panel">
        <div class="grid md:grid-cols-1 gap-6 max-w-lg mx-auto">
          {individualTiers.map((tier) => (
            <div class="card-reveal p-8 border border-black/10 bg-white rounded-sm transition-all duration-300 hover:border-green hover:shadow-lg hover:shadow-green/10">
              <p class="text-black/50 text-sm mb-2">{tier.ideal}</p>
              <h4 class="font-display font-bold text-xl text-black mb-2">{tier.name}</h4>
              <div class="mb-6">
                <span class="font-display font-black text-3xl text-red">{tier.price}</span>
                <span class="text-sm text-black/40">{tier.period}</span>
              </div>
              <ul class="space-y-3 mb-8">
                {tier.features.map(f => (
                  <li class="flex items-start gap-2 text-sm text-black/60">
                    <svg class="w-4 h-4 mt-0.5 shrink-0 fill-green" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                    {f}
                  </li>
                ))}
              </ul>
              <a href="https://erp.kenyachamber.or.ke/kncci_meru/membership" target="_blank" rel="noopener noreferrer" class="block text-center py-3 bg-black text-white font-display font-bold text-sm rounded-sm hover:bg-green transition-colors duration-300">
                Register Now
              </a>
            </div>
          ))}
        </div>
      </div>

      <!-- Company / Corporate Tab -->
      <div id="panel-company" class="tier-panel hidden">
        <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
          {companyTiers.map((tier) => (
            <div class:list={[
              'card-reveal p-8 border rounded-sm transition-all duration-300 relative hover:shadow-lg',
              tier.popular ? 'border-red bg-black text-white hover:border-green hover:shadow-green/20' : 'border-black/10 bg-white hover:border-green hover:shadow-green/10'
            ]}>
              {tier.popular && <div class="absolute top-0 right-6 -translate-y-1/2 bg-red text-white font-mono text-xs px-3 py-1 uppercase tracking-wider">Popular</div>}
              <p class:list={['text-sm mb-2', tier.popular ? 'text-white/50' : 'text-black/50']}>{tier.ideal}</p>
              <h4 class:list={['font-display font-bold text-lg mb-2', tier.popular ? 'text-white' : 'text-black']}>{tier.name}</h4>
              <div class="mb-6">
                <span class:list={['font-display font-black text-3xl', tier.popular ? 'text-green' : 'text-red']}>{tier.price}</span>
                <span class:list={['text-sm', tier.popular ? 'text-white/50' : 'text-black/40']}>{tier.period}</span>
              </div>
              <ul class="space-y-3 mb-8">
                {tier.features.map(f => (
                  <li class:list={['flex items-start gap-2 text-sm', tier.popular ? 'text-white/70' : 'text-black/60']}>
                    <svg class="w-4 h-4 mt-0.5 shrink-0 fill-green" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                    {f}
                  </li>
                ))}
              </ul>
              <a href="https://erp.kenyachamber.or.ke/kncci_meru/membership" target="_blank" rel="noopener noreferrer" class:list={[
                'block text-center py-3 font-display font-bold text-sm rounded-sm transition-colors duration-300',
                tier.popular ? 'bg-red text-white hover:bg-green' : 'bg-black text-white hover:bg-green'
              ]}>
                Register Now
              </a>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <script>
    const tabs = document.querySelectorAll('.tier-tab');
    const panels = document.querySelectorAll('.tier-panel');
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const target = tab.getAttribute('data-tab');
        tabs.forEach(t => {
          t.classList.remove('bg-black', 'text-white');
          t.classList.add('text-black/50');
        });
        tab.classList.add('bg-black', 'text-white');
        tab.classList.remove('text-black/50');
        panels.forEach(p => p.classList.add('hidden'));
        document.getElementById(`panel-${target}`)?.classList.remove('hidden');
      });
    });
  </script>

  <SectionDivider class="my-0" />

  <!-- Detailed Benefits -->
  <section class="bg-black py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="font-mono text-red text-xs uppercase tracking-widest mb-2">What You Gain</p>
        <h2 class="font-display font-black text-3xl lg:text-4xl text-white">Detailed Benefits</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {benefits.map((b) => (
          <div class="card-reveal p-6 border border-white/10 rounded-sm">
            <div class="w-10 h-10 rounded-sm bg-red/20 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 fill-red" viewBox="0 0 24 24"><path d={b.icon} /></svg>
            </div>
            <h3 class="font-display font-bold text-base text-white mb-2">{b.title}</h3>
            <p class="text-white/60 text-sm leading-relaxed">{b.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <ScrollReveal />

  <SectionDivider class="my-0" />

  <!-- Chamber Services -->
  <section class="bg-white py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="font-mono text-red text-xs uppercase tracking-widest mb-2">Services</p>
        <h2 class="font-display font-black text-3xl lg:text-4xl text-black">Chamber Services</h2>
      </div>
      <div class="space-y-4">
        {services.map((s) => (
          <div id={s.id} class="card-reveal border border-black/10 bg-white p-6 lg:p-8 rounded-sm scroll-mt-24 hover:border-green transition-colors duration-300">
            <div class="flex items-start gap-4">
              <div class="flex-1">
                <h3 class="font-display font-bold text-lg text-black mb-2">{s.title}</h3>
                <p class="text-black/60 text-sm leading-relaxed mb-3">{s.desc}</p>
                <a href="https://erp.kenyachamber.or.ke/kncci_meru/membership" target="_blank" rel="noopener noreferrer" class="text-red text-sm font-medium hover:underline">
                  How to Apply &rarr;
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <SectionDivider class="my-0" />

  <!-- Testimonials placeholder -->
  <section class="bg-black py-16 lg:py-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="font-mono text-red text-xs uppercase tracking-widest mb-3">Testimonials</p>
      <h2 class="font-display font-black text-3xl lg:text-4xl text-white mb-10">What Our Members Say</h2>
      <div class="border border-dashed border-white/20 rounded-sm p-10">
        <p class="text-white/40 text-sm italic">
          "[Member testimonial — real quote from a Meru business pending.]" — [Business Name], [Sector]
        </p>
      </div>
    </div>
  </section>

  <SectionDivider class="my-0" />

  <!-- CTA -->
  <section class="bg-red py-16 lg:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display font-black text-3xl lg:text-4xl text-white mb-4">
        Ready to Experience These Benefits?
      </h2>
      <p class="text-white/80 text-lg mb-8 max-w-xl mx-auto leading-relaxed">
        Join KNCCI Meru Chapter today and unlock advocacy, connections, and growth for your business.
      </p>
      <a href="https://erp.kenyachamber.or.ke/kncci_meru/membership" target="_blank" rel="noopener noreferrer" class="inline-flex items-center px-10 py-4 bg-white text-black font-display font-bold text-lg rounded-sm hover:bg-green transition-colors">
        Register Now
      </a>
    </div>
  </section>
</Base>
