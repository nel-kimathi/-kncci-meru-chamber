---
import Base from '../layouts/Base.astro';
import SectionDivider from '../components/SectionDivider.astro';
import ScrollReveal from '../components/ScrollReveal.astro';

const faqs = [
  { q: "How do I become a member?", a: "Visit our Register page and fill in the membership application form. The secretariat will review your application and get back to you within 5 business days." },
  { q: "What are the membership fees?", a: "Membership is tiered: Individual/SME at KES 2,500/year, Registered Business at KES 5,000/year, Corporate & SACCO at KES 50,000/year, and more. See the Benefits page for full details." },
  { q: "How do I apply for a Certificate of Origin?", a: "Contact the secretariat or visit our office with the required export documentation. Processing typically takes 2-3 business days. Members receive preferential rates." },
  { q: "Can non-members use Chamber services?", a: "Some services, like attending public events, are open to all. However, core services like Certificates of Origin, arbitration, and advocacy representation are exclusive to registered members." },
  { q: "How do I contact the Chamber?", a: "You can reach us via the form on this page, by phone during office hours (Mon–Fri, 9:00 AM – 5:00 PM), or by visiting our office at the NHIF Building, 1st Floor, opposite Royal Business Park, Meru." },
];

const facebookPageUrl = "https://web.facebook.com/profile.php?id=61572837654875";

const socials = [
  { label: 'Facebook', href: facebookPageUrl, icon: 'M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z' },
  { label: 'X', href: facebookPageUrl, icon: 'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z' },
  { label: 'Instagram', href: facebookPageUrl, icon: 'M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z' },
  { label: 'LinkedIn', href: facebookPageUrl, icon: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z' },
  { label: 'YouTube', href: facebookPageUrl, icon: 'M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z' },
  { label: 'WhatsApp', href: 'https://wa.me/254794924309', icon: 'M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z' },
];
---

<Base title="Contact Us" description="Get in touch with KNCCI Meru Chapter — office location, phone, email, and contact form.">
  <!-- Page Hero -->
  <section class="relative bg-black py-20 lg:py-32 min-h-[50vh] flex items-center">
    <div class="absolute inset-0">
      <img src="/images/contact-us-hero-contact-page/Meru-Chamber-Contact-us.jpg" alt="KNCCI Meru Chapter — Contact Us" class="w-full h-full object-cover object-top opacity-50" />
      <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/50 to-transparent"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
      <div class="max-w-xl lg:max-w-2xl">
        <p class="font-mono text-red text-xs uppercase tracking-widest mb-3">Get in Touch</p>
        <h1 class="font-display font-black text-4xl sm:text-5xl lg:text-5xl text-white leading-tight mb-4">Contact Us</h1>
        <p class="text-white/70 text-lg lg:text-xl leading-relaxed">
          Have a question about membership, services, or chamber activities? We'd love to hear from you.
        </p>
      </div>
    </div>
  </section>

  <SectionDivider class="my-0" />

  <!-- Map + Info + Form -->
  <section class="bg-white py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16">
        <!-- Left: Map + Info -->
        <div>
          <!-- Map embed -->
          <div class="aspect-[4/3] rounded-sm overflow-hidden bg-black/10 mb-8 border border-black/10">
            <iframe
              src="https://maps.google.com/maps?q=0.04779416624092856,37.654180041809006&t=&z=17&ie=UTF8&iwloc=&output=embed"
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="KNCCI Meru Chapter office location"
            ></iframe>
          </div>

          <!-- Contact info -->
          <div class="space-y-4 mb-8">
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 mt-0.5 shrink-0 fill-red" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 010-5 2.5 2.5 0 010 5z"/></svg>
              <div>
                <h3 class="font-display font-bold text-sm text-black">Office Address</h3>
                <p class="text-black/60 text-sm">1st Floor, NHIF Building, opposite Royal Business Park, Meru</p>
                <a href="https://maps.google.com/?q=2MX3%2B3F+Meru" target="_blank" rel="noopener noreferrer" class="text-red text-xs font-medium hover:underline mt-1 inline-block">
                  Get Directions &rarr;
                </a>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 mt-0.5 shrink-0 fill-red" viewBox="0 0 24 24"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
              <div>
                <h3 class="font-display font-bold text-sm text-black">Phone</h3>
                <a href="tel:+254794924309" class="text-black/60 text-sm hover:text-red transition-colors">0794 924 309</a>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 mt-0.5 shrink-0 fill-red" viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
              <div>
                <h3 class="font-display font-bold text-sm text-black">Email</h3>
                <a href="mailto:info@meruchamber.co.ke" class="text-black/60 text-sm hover:text-red transition-colors">info@meruchamber.co.ke</a>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 mt-0.5 shrink-0 fill-red" viewBox="0 0 24 24"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/></svg>
              <div>
                <h3 class="font-display font-bold text-sm text-black">Office Hours</h3>
                <p class="text-black/60 text-sm">Monday – Friday, 9:00 AM – 5:00 PM</p>
              </div>
            </div>
          </div>

          <!-- Social links -->
          <div>
            <h3 class="font-display font-bold text-sm text-black mb-3">Follow Us</h3>
            <div class="flex gap-3">
              {socials.map(s => (
                <a
                  href={s.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="w-10 h-10 rounded-sm bg-black/5 hover:bg-red flex items-center justify-center text-black/40 hover:text-white transition-colors"
                  aria-label={s.label}
                >
                  <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d={s.icon} /></svg>
                </a>
              ))}
            </div>
          </div>
        </div>

        <!-- Right: Contact Form -->
        <div>
          <h2 class="font-display font-black text-2xl text-black mb-6">Send Us a Message</h2>
          <form
            action="https://formspree.io/f/[FORM_ID]"
            method="POST"
            class="space-y-5"
          >
            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label for="name" class="block font-mono text-xs text-black/50 uppercase tracking-wider mb-1.5">Name</label>
                <input type="text" id="name" name="name" required class="w-full px-4 py-2.5 border border-black/20 bg-white text-black text-sm rounded-sm focus:outline-none focus:border-red transition-colors" />
              </div>
              <div>
                <label for="email" class="block font-mono text-xs text-black/50 uppercase tracking-wider mb-1.5">Email</label>
                <input type="email" id="email" name="email" required class="w-full px-4 py-2.5 border border-black/20 bg-white text-black text-sm rounded-sm focus:outline-none focus:border-red transition-colors" />
              </div>
            </div>
            <div>
              <label for="phone" class="block font-mono text-xs text-black/50 uppercase tracking-wider mb-1.5">Phone</label>
              <input type="tel" id="phone" name="phone" class="w-full px-4 py-2.5 border border-black/20 bg-white text-black text-sm rounded-sm focus:outline-none focus:border-red transition-colors" />
            </div>
            <div>
              <label for="subject" class="block font-mono text-xs text-black/50 uppercase tracking-wider mb-1.5">Subject</label>
              <select id="subject" name="subject" required class="w-full px-4 py-2.5 border border-black/20 bg-white text-black text-sm rounded-sm focus:outline-none focus:border-red transition-colors">
                <option value="">Select a subject</option>
                <option value="membership">Membership Enquiry</option>
                <option value="certificate-of-origin">Certificate of Origin</option>
                <option value="events">Events</option>
                <option value="advocacy">Business Advocacy</option>
                <option value="general">General Enquiry</option>
              </select>
            </div>
            <div>
              <label for="message" class="block font-mono text-xs text-black/50 uppercase tracking-wider mb-1.5">Message</label>
              <textarea id="message" name="message" rows="5" required class="w-full px-4 py-2.5 border border-black/20 bg-white text-black text-sm rounded-sm focus:outline-none focus:border-red transition-colors resize-none"></textarea>
            </div>
            <button type="submit" class="w-full sm:w-auto px-8 py-3 bg-red text-white font-display font-bold text-sm rounded-sm hover:bg-green transition-colors duration-300">
              Send Message
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <ScrollReveal />

  <SectionDivider class="my-0" />

  <!-- FAQ -->
  <section class="bg-black py-16 lg:py-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="font-mono text-red text-xs uppercase tracking-widest mb-2">FAQ</p>
        <h2 class="font-display font-black text-3xl lg:text-4xl text-white">Frequently Asked Questions</h2>
      </div>
      <div class="space-y-3">
        {faqs.map((faq, i) => (
          <div class="border border-white/10 rounded-sm overflow-hidden">
            <button
              class="faq-toggle w-full flex items-center justify-between px-6 py-4 text-left hover:bg-white/5 transition-colors"
              aria-expanded="false"
            >
              <span class="font-display font-bold text-base text-white pr-4">{faq.q}</span>
              <svg class="w-5 h-5 shrink-0 fill-white/40 transition-transform duration-200" viewBox="0 0 24 24"><path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6z"/></svg>
            </button>
            <div class="faq-answer hidden px-6 pb-4">
              <p class="text-white/60 text-sm leading-relaxed">{faq.a}</p>
            </div>
          </div>
        ))}
      </div>
      <script is:inline>
        document.querySelectorAll('.faq-toggle').forEach(btn => {
          btn.addEventListener('click', () => {
            const answer = btn.nextElementSibling;
            const isOpen = !answer.classList.contains('hidden');
            document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
            document.querySelectorAll('.faq-toggle').forEach(b => {
              b.setAttribute('aria-expanded', 'false');
              b.querySelector('svg').style.transform = '';
            });
            if (!isOpen) {
              answer.classList.remove('hidden');
              btn.setAttribute('aria-expanded', 'true');
              btn.querySelector('svg').style.transform = 'rotate(180deg)';
            }
          });
        });
      </script>
    </div>
  </section>
</Base>
