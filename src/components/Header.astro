---
const nav = [
  { label: 'Home', href: '/' },
  { label: 'About Us', href: '/about' },
  { label: 'Secretariat', href: '/secretariat' },
  { label: 'Benefits', href: '/benefits' },
  { label: 'How to Join', href: '/register' },
  { label: 'Events', href: '/events' },
  { label: 'Gallery', href: '/gallery' },
  { label: 'Contact', href: '/contact' },
];

const registerUrl = 'https://erp.kenyachamber.or.ke/kncci_meru/membership';

interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---
<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 bg-white border-b border-ink/10 transition-all duration-300"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <!-- Logo — replace /images/logo.png with your actual logo file -->
      <a href="/" class="flex items-center gap-3 shrink-0">
        <img
          src="/images/logo/KNCCI LOGO final V1.png"
          alt="KNCCI Meru Chapter"
          class="h-10 lg:h-12 w-auto"
          onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
        />
        <div class="hidden items-center gap-3">
          <div class="w-10 h-10 lg:w-12 lg:h-12 rounded-full border-2 border-red flex items-center justify-center">
            <span class="text-red font-display font-bold text-xs lg:text-sm leading-none">KNCCI</span>
          </div>
          <div>
            <span class="block text-ink font-display font-bold text-sm lg:text-base leading-tight">Meru Chapter</span>
            <span class="block text-ink/50 text-[10px] lg:text-xs tracking-wider uppercase font-mono">Kenya National Chamber</span>
          </div>
        </div>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center justify-between flex-1 mx-8" aria-label="Main navigation">
        {nav.map(item => (
          <a
            href={item.href}
            class:list={[
              "px-3 py-2 text-base font-medium transition-colors duration-200 rounded-[20px]",
              isActive(item.href) ? "text-red bg-red/10 font-semibold" : "text-ink/60 hover:text-red",
            ]}
          >
            {item.label}
          </a>
        ))}
      </nav>

      <!-- Register CTA -->
      <a
        href={registerUrl}
        target="_blank"
        rel="noopener noreferrer"
        id="register-btn"
        class="relative overflow-hidden px-5 py-2.5 lg:px-6 lg:py-3 bg-red text-white font-display font-bold text-sm lg:text-base rounded-sm hover:bg-red/90 transition-all duration-200 group"
      >
        <span class="relative z-10">Register</span>
      </a>

      <!-- Mobile menu button -->
      <button
        id="mobile-toggle"
        class="lg:hidden p-2 text-ink"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="menu-open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          <path id="menu-close" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" class="hidden" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <nav
    id="mobile-menu"
    class="lg:hidden hidden bg-white border-t border-ink/10"
    aria-label="Mobile navigation"
  >
    <div class="px-4 py-4 space-y-1">
      {nav.map(item => (
        <a
          href={item.href}
          class:list={[
            "block px-3 py-2.5 text-sm font-medium rounded-sm transition-colors",
            isActive(item.href) ? "text-red bg-red/10 font-semibold" : "text-ink/60 hover:text-red hover:bg-red/5",
          ]}
        >
          {item.label}
        </a>
      ))}
      <a
        href={registerUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="block px-3 py-2.5 bg-red text-white text-sm font-display font-bold text-center rounded-sm mt-3"
      >
        Register Now
      </a>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');
  const menuOpen = document.getElementById('menu-open');
  const menuClose = document.getElementById('menu-close');

  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
    menuOpen?.classList.toggle('hidden', open);
    menuClose?.classList.toggle('hidden', !open);
  });
</script>
