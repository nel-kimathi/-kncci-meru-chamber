---
interface Props {
  class?: string;
  size?: number;
}
const { class: cls = '', size = 160 } = Astro.props;
---
<svg
  class={cls}
  width={size}
  height={size}
  viewBox="0 0 200 200"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-label="KNCCI Meru Chapter seal"
>
  <!-- Outer ring -->
  <circle cx="100" cy="100" r="96" stroke="#ea2430" stroke-width="3" fill="none" />
  <circle cx="100" cy="100" r="88" stroke="#ea2430" stroke-width="1" fill="none" />

  <!-- Circular text path -->
  <defs>
    <path
      id="topArc"
      d="M 100,100 m -78,0 a 78,78 0 1,1 156,0"
    />
    <path
      id="bottomArc"
      d="M 100,100 m 78,0 a 78,78 0 1,1 -156,0"
    />
  </defs>
  <text font-family="Inter, sans-serif" font-size="8.5" font-weight="600" fill="#ea2430" letter-spacing="2.5">
    <textPath href="#topArc" startOffset="50%" text-anchor="middle">
      KENYA NATIONAL CHAMBER OF COMMERCE
    </textPath>
  </text>
  <text font-family="Inter, sans-serif" font-size="8.5" font-weight="600" fill="#ea2430" letter-spacing="2.5">
    <textPath href="#bottomArc" startOffset="50%" text-anchor="middle">
      AND INDUSTRY — MERU CHAPTER
    </textPath>
  </text>

  <!-- Decorative dots at 3 and 9 o'clock -->
  <circle cx="22" cy="100" r="2.5" fill="#ea2430" />
  <circle cx="178" cy="100" r="2.5" fill="#ea2430" />

  <!-- Mount Kenya silhouette -->
  <path
    d="M 68 130 L 80 95 L 88 108 L 96 78 L 100 70 L 104 78 L 112 108 L 120 95 L 132 130 Z"
    fill="#ea2430"
    opacity="0.9"
  />
  <!-- Snow cap -->
  <path
    d="M 96 78 L 100 70 L 104 78 L 100 82 Z"
    fill="#F3ECE0"
  />

  <!-- Coffee leaf left -->
  <path
    d="M 75 118 C 65 110, 55 115, 58 125 C 61 135, 72 132, 75 125 Z"
    fill="#ea2430"
    opacity="0.7"
  />
  <!-- Coffee leaf right -->
  <path
    d="M 125 118 C 135 110, 145 115, 142 125 C 139 135, 128 132, 125 125 Z"
    fill="#ea2430"
    opacity="0.7"
  />

  <!-- Coffee berries cluster -->
  <circle cx="92" cy="128" r="3" fill="#ea2430" />
  <circle cx="100" cy="131" r="3" fill="#ea2430" />
  <circle cx="108" cy="128" r="3" fill="#ea2430" />
  <circle cx="96" cy="135" r="2.5" fill="#ea2430" opacity="0.8" />
  <circle cx="104" cy="135" r="2.5" fill="#ea2430" opacity="0.8" />

  <!-- Year Est. line -->
  <text
    x="100" y="153"
    text-anchor="middle"
    font-family="'IBM Plex Mono', monospace"
    font-size="9"
    font-weight="500"
    fill="#ea2430"
    letter-spacing="1"
  >EST. 1965</text>
</svg>
